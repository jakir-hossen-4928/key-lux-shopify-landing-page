        const id = setInterval(() => {
          setTime((t) => {
            let { h, m, s } = t;
            if (s > 0) s--;
            else { s = 59; if (m > 0) m--; else { m = 59; if (h > 0) h--; else h = 0; } }
            return { h, m, s };
          });
        }, 1000);
        return () => clearInterval(id);
      }, []);
      return time;
