{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-offer-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-countdown-offer-gradient-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, {{ block.settings.gradient_color }}, transparent 70%);
    opacity: {{ block.settings.gradient_opacity }};
    pointer-events: none;
  }

  .ai-countdown-offer-container-{{ ai_gen_id }} {
    position: relative;
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-countdown-offer-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border-radius: 50px;
    border: 1px solid {{ block.settings.badge_border_color }};
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_font_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: {{ block.settings.badge_margin_bottom }}px;
  }

  .ai-countdown-offer-pulse-{{ ai_gen_id }} {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: {{ block.settings.badge_text_color }};
    animation: ai-countdown-pulse-{{ ai_gen_id }} 2s ease-in-out infinite;
  }

  @keyframes ai-countdown-pulse-{{ ai_gen_id }} {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(1.2);
    }
  }

  .ai-countdown-offer-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    line-height: 1.1;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-countdown-offer-highlight-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.highlight_color_1 }}, {{ block.settings.highlight_color_2 }});
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ai-countdown-offer-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    max-width: 600px;
    margin: 0 auto {{ block.settings.description_margin_bottom }}px;
    line-height: 1.6;
  }

  .ai-countdown-offer-timer-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.timer_gap }}px;
    margin-bottom: {{ block.settings.timer_margin_bottom }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-offer-cell-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ai-countdown-offer-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.timer_number_size }}px;
    font-weight: {{ block.settings.timer_number_weight }};
    background-color: {{ block.settings.timer_bg_color }};
    color: {{ block.settings.timer_text_color }};
    border: 1px solid {{ block.settings.timer_border_color }};
    border-radius: {{ block.settings.timer_border_radius }}px;
    padding: {{ block.settings.timer_padding_vertical }}px {{ block.settings.timer_padding_horizontal }}px;
    min-width: {{ block.settings.timer_min_width }}px;
    font-variant-numeric: tabular-nums;
  }

  .ai-countdown-offer-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.timer_label_size }}px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: {{ block.settings.timer_label_color }};
    margin-top: 8px;
  }

  .ai-countdown-offer-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-countdown-offer-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-offer-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px 16px {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-countdown-offer-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.6 }}px;
    }

    .ai-countdown-offer-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.timer_number_size | times: 0.7 }}px;
      min-width: {{ block.settings.timer_min_width | times: 0.7 }}px;
      padding: {{ block.settings.timer_padding_vertical | times: 0.7 }}px {{ block.settings.timer_padding_horizontal | times: 0.7 }}px;
    }

    .ai-countdown-offer-timer-{{ ai_gen_id }} {
      gap: {{ block.settings.timer_gap | times: 0.7 }}px;
    }
  }
{% endstyle %}

<countdown-offer-{{ ai_gen_id }}
  class="ai-countdown-offer-{{ ai_gen_id }}"
  data-end-year="{{ block.settings.end_year }}"
  data-end-month="{{ block.settings.end_month }}"
  data-end-day="{{ block.settings.end_day }}"
  data-end-hour="{{ block.settings.end_hour }}"
  data-end-minute="{{ block.settings.end_minute }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-countdown-offer-gradient-{{ ai_gen_id }}"></div>
  
  <div class="ai-countdown-offer-container-{{ ai_gen_id }}">
    {% if block.settings.show_badge %}
      <div class="ai-countdown-offer-badge-{{ ai_gen_id }}">
        <span class="ai-countdown-offer-pulse-{{ ai_gen_id }}"></span>
        {{ block.settings.badge_text }}
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h2 class="ai-countdown-offer-heading-{{ ai_gen_id }}">
        {% if block.settings.highlight_text != blank %}
          <span class="ai-countdown-offer-highlight-{{ ai_gen_id }}">{{ block.settings.highlight_text }}</span>
        {% endif %}
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <p class="ai-countdown-offer-description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </p>
    {% endif %}

    <div class="ai-countdown-offer-timer-{{ ai_gen_id }}">
      {% if block.settings.show_days %}
        <div class="ai-countdown-offer-cell-{{ ai_gen_id }}">
          <div class="ai-countdown-offer-number-{{ ai_gen_id }}" data-unit="days">00</div>
          <span class="ai-countdown-offer-label-{{ ai_gen_id }}">{{ block.settings.days_label }}</span>
        </div>
      {% endif %}

      <div class="ai-countdown-offer-cell-{{ ai_gen_id }}">
        <div class="ai-countdown-offer-number-{{ ai_gen_id }}" data-unit="hours">00</div>
        <span class="ai-countdown-offer-label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</span>
      </div>

      <div class="ai-countdown-offer-cell-{{ ai_gen_id }}">
        <div class="ai-countdown-offer-number-{{ ai_gen_id }}" data-unit="minutes">00</div>
        <span class="ai-countdown-offer-label-{{ ai_gen_id }}">{{ block.settings.minutes_label }}</span>
      </div>

      <div class="ai-countdown-offer-cell-{{ ai_gen_id }}">
        <div class="ai-countdown-offer-number-{{ ai_gen_id }}" data-unit="seconds">00</div>
        <span class="ai-countdown-offer-label-{{ ai_gen_id }}">{{ block.settings.seconds_label }}</span>
      </div>
    </div>

    {% if block.settings.button_text != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-countdown-offer-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</countdown-offer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownOffer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.timer = null;
      }

      connectedCallback() {
        this.startCountdown();
      }

      disconnectedCallback() {
        if (this.timer) {
          clearInterval(this.timer);
        }
      }

      startCountdown() {
        const updateTimer = () => {
          const now = new Date();
          
          const year = parseInt(this.dataset.endYear) || now.getFullYear();
          const month = parseInt(this.dataset.endMonth) || (now.getMonth() + 1);
          const day = parseInt(this.dataset.endDay) || now.getDate();
          const hour = parseInt(this.dataset.endHour) || 23;
          const minute = parseInt(this.dataset.endMinute) || 59;

          const targetDate = new Date(year, month - 1, day, hour, minute, 0, 0);
          const distance = targetDate.getTime() - now.getTime();

          if (distance < 0) {
            this.displayTime(0, 0, 0, 0);
            if (this.timer) {
              clearInterval(this.timer);
            }
            return;
          }

          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          this.displayTime(days, hours, minutes, seconds);
        };

        updateTimer();
        this.timer = setInterval(updateTimer, 1000);
      }

      displayTime(days, hours, minutes, seconds) {
        const pad = (num) => String(num).padStart(2, '0');

        const daysEl = this.querySelector('[data-unit="days"]');
        const hoursEl = this.querySelector('[data-unit="hours"]');
        const minutesEl = this.querySelector('[data-unit="minutes"]');
        const secondsEl = this.querySelector('[data-unit="seconds"]');

        if (daysEl) daysEl.textContent = pad(days);
        if (hoursEl) hoursEl.textContent = pad(hours);
        if (minutesEl) minutesEl.textContent = pad(minutes);
        if (secondsEl) secondsEl.textContent = pad(seconds);
      }
    }

    customElements.define('countdown-offer-{{ ai_gen_id }}', CountdownOffer{{ ai_gen_id }});
  })();
</script>

