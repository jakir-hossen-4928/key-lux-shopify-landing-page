{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-problem-solution-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_left_right }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-bottom: {{ block.settings.border_width }}px {{ block.settings.border_style }} {{ block.settings.border_color }};
  }

  .ai-problem-solution-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-problem-solution-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_text_align }};
    max-width: {{ block.settings.header_max_width }}px;
    margin: 0 auto {{ block.settings.header_margin_bottom }}px;
    padding: {{ block.settings.header_padding_top }}px {{ block.settings.header_padding_left_right }}px {{ block.settings.header_padding_bottom }}px;
  }

  .ai-problem-solution-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    line-height: {{ block.settings.title_line_height }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    color: {{ block.settings.title_color }};
    letter-spacing: {{ block.settings.title_letter_spacing }};
    text-transform: {{ block.settings.title_text_transform }};
  }

  .ai-problem-solution-title-{{ ai_gen_id }} strong {
    color: {{ block.settings.highlight_color }};
    font-weight: {{ block.settings.highlight_font_weight }};
  }

  .ai-problem-solution-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_font_size }}px;
    font-weight: {{ block.settings.subtitle_font_weight }};
    line-height: {{ block.settings.subtitle_line_height }};
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    letter-spacing: {{ block.settings.subtitle_letter_spacing }};
  }

  .ai-problem-solution-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.grid_gap }}px;
  }

  @media (min-width: 768px) {
    .ai-problem-solution-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.desktop_columns }}, 1fr);
    }

    .ai-problem-solution-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_desktop }}px;
    }

    .ai-problem-solution-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_font_size_desktop }}px;
    }
  }

  .ai-problem-solution-card-{{ ai_gen_id }} {
    border-radius: {{ block.settings.card_border_radius }}px;
    border: {{ block.settings.card_border_width }}px {{ block.settings.card_border_style }} {{ block.settings.card_border_color }};
    background-color: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding_top }}px {{ block.settings.card_padding_left_right }}px {{ block.settings.card_padding_bottom }}px;
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
  }

  .ai-problem-solution-card-{{ ai_gen_id }}.problem {
    border-color: {{ block.settings.problem_card_border_color }};
    background-color: {{ block.settings.problem_card_background }};
  }

  .ai-problem-solution-card-{{ ai_gen_id }}.solution {
    border-color: {{ block.settings.solution_border_color }};
    {% if block.settings.solution_enable_gradient %}
      background: linear-gradient({{ block.settings.solution_gradient_angle }}deg, {{ block.settings.solution_gradient_start }}, {{ block.settings.solution_gradient_end }});
    {% else %}
      background-color: {{ block.settings.solution_card_background }};
    {% endif %}
    box-shadow: 0 0 {{ block.settings.solution_glow_size }}px {{ block.settings.solution_glow_color }};
  }

  .ai-problem-solution-card-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: {{ block.settings.label_font_weight }};
    text-transform: {{ block.settings.label_text_transform }};
    letter-spacing: {{ block.settings.label_letter_spacing }};
    margin-bottom: {{ block.settings.label_margin_bottom }}px;
    line-height: {{ block.settings.label_line_height }};
  }

  .ai-problem-solution-card-{{ ai_gen_id }}.problem .ai-problem-solution-card-label-{{ ai_gen_id }} {
    color: {{ block.settings.problem_label_color }};
  }

  .ai-problem-solution-card-{{ ai_gen_id }}.solution .ai-problem-solution-card-label-{{ ai_gen_id }} {
    color: {{ block.settings.solution_label_color }};
  }

  .ai-problem-solution-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.list_item_gap }}px;
  }

  .ai-problem-solution-list-item-{{ ai_gen_id }} {
    display: flex;
    align-items: {{ block.settings.list_item_align }};
    gap: {{ block.settings.list_item_icon_gap }}px;
  }

  .ai-problem-solution-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    border-radius: {{ block.settings.icon_border_radius }}%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: {{ block.settings.icon_margin_top }}px;
    border: {{ block.settings.icon_border_width }}px {{ block.settings.icon_border_style }} transparent;
  }

  .ai-problem-solution-card-{{ ai_gen_id }}.problem .ai-problem-solution-icon-{{ ai_gen_id }} {
    background-color: {{ block.settings.problem_icon_bg }};
    border-color: {{ block.settings.problem_icon_border_color }};
  }

  .ai-problem-solution-card-{{ ai_gen_id }}.solution .ai-problem-solution-icon-{{ ai_gen_id }} {
    background-color: {{ block.settings.solution_icon_bg }};
    border-color: {{ block.settings.solution_icon_border_color }};
  }

  .ai-problem-solution-icon-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_svg_size }}px;
    height: {{ block.settings.icon_svg_size }}px;
    stroke-width: {{ block.settings.icon_stroke_width }};
  }

  .ai-problem-solution-card-{{ ai_gen_id }}.problem .ai-problem-solution-icon-{{ ai_gen_id }} svg {
    stroke: {{ block.settings.problem_icon_color }};
  }

  .ai-problem-solution-card-{{ ai_gen_id }}.solution .ai-problem-solution-icon-{{ ai_gen_id }} svg {
    stroke: {{ block.settings.solution_icon_color }};
  }

  .ai-problem-solution-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.list_text_font_size }}px;
    font-weight: {{ block.settings.list_text_font_weight }};
    line-height: {{ block.settings.list_text_line_height }};
    letter-spacing: {{ block.settings.list_text_letter_spacing }};
  }

  .ai-problem-solution-card-{{ ai_gen_id }}.problem .ai-problem-solution-text-{{ ai_gen_id }} {
    color: {{ block.settings.problem_text_color }};
  }

  .ai-problem-solution-card-{{ ai_gen_id }}.solution .ai-problem-solution-text-{{ ai_gen_id }} {
    color: {{ block.settings.solution_text_color }};
  }

  @media (max-width: 767px) {
    .ai-problem-solution-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_left_right_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-problem-solution-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_top_mobile }}px {{ block.settings.card_padding_left_right_mobile }}px {{ block.settings.card_padding_bottom_mobile }}px;
    }

    .ai-problem-solution-grid-{{ ai_gen_id }} {
      gap: {{ block.settings.grid_gap_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-problem-solution-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-problem-solution-container-{{ ai_gen_id }}">
    <div class="ai-problem-solution-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-problem-solution-title-{{ ai_gen_id }}">
          {{ block.settings.title }}
        </h2>
      {% endif %}
