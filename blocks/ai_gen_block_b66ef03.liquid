        <div class="ai-problem-solution-subtitle-{{ ai_gen_id }}">
          {{ block.settings.subtitle }}
        </div>
      {% endif %}
    </div>

    <div class="ai-problem-solution-grid-{{ ai_gen_id }}">
      <div class="ai-problem-solution-card-{{ ai_gen_id }} problem">
        <div class="ai-problem-solution-card-label-{{ ai_gen_id }}">
          {{ block.settings.problem_label }}
        </div>
        <ul class="ai-problem-solution-list-{{ ai_gen_id }}">
          {% if block.settings.problem_1 != blank %}
            <li class="ai-problem-solution-list-item-{{ ai_gen_id }}">
              <span class="ai-problem-solution-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </span>
              <span class="ai-problem-solution-text-{{ ai_gen_id }}">{{ block.settings.problem_1 }}</span>
            </li>
          {% endif %}
          {% if block.settings.problem_2 != blank %}
            <li class="ai-problem-solution-list-item-{{ ai_gen_id }}">
              <span class="ai-problem-solution-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </span>
              <span class="ai-problem-solution-text-{{ ai_gen_id }}">{{ block.settings.problem_2 }}</span>
            </li>
          {% endif %}
          {% if block.settings.problem_3 != blank %}
            <li class="ai-problem-solution-list-item-{{ ai_gen_id }}">
              <span class="ai-problem-solution-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </span>
              <span class="ai-problem-solution-text-{{ ai_gen_id }}">{{ block.settings.problem_3 }}</span>
            </li>
          {% endif %}
        </ul>
      </div>

      <div class="ai-problem-solution-card-{{ ai_gen_id }} solution">
        <div class="ai-problem-solution-card-label-{{ ai_gen_id }}">
          {{ block.settings.solution_label }}
        </div>
        <ul class="ai-problem-solution-list-{{ ai_gen_id }}">
          {% if block.settings.solution_1 != blank %}
            <li class="ai-problem-solution-list-item-{{ ai_gen_id }}">
              <span class="ai-problem-solution-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </span>
              <span class="ai-problem-solution-text-{{ ai_gen_id }}">{{ block.settings.solution_1 }}</span>
            </li>
          {% endif %}
          {% if block.settings.solution_2 != blank %}
            <li class="ai-problem-solution-list-item-{{ ai_gen_id }}">
              <span class="ai-problem-solution-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </span>
              <span class="ai-problem-solution-text-{{ ai_gen_id }}">{{ block.settings.solution_2 }}</span>
            </li>
          {% endif %}
          {% if block.settings.solution_3 != blank %}
            <li class="ai-problem-solution-list-item-{{ ai_gen_id }}">
              <span class="ai-problem-solution-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </span>
              <span class="ai-problem-solution-text-{{ ai_gen_id }}">{{ block.settings.solution_3 }}</span>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </div>
</div>

