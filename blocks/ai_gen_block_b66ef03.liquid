{% doc %}
  @prompt
    create a section based on this code import { X, Check } from "lucide-react";
    
    const problems = ["Cheap keys break easily", "Outdated, plastic design", "Poor durability over time"];
    const solutions = ["Premium aerospace materials", "Modern, minimalist design", "Engineered to last for years"];
    
    const ProblemSolution = () => {
      return (
        <section className="py-24 border-b border-border">
          <div className="container">
            <div className="text-center max-w-2xl mx-auto mb-16">
              <h2 className="text-4xl md:text-5xl font-black tracking-tight">Stop settling for <span className="text-primary">ordinary</span></h2>
              <p className="mt-4 text-muted-foreground">The difference between a key and a statement.</p>
            </div>
            <div className="grid md:grid-cols-2 gap-6">
              <div className="rounded-2xl border border-border bg-card p-8">
                <div className="text-xs uppercase tracking-widest text-destructive mb-4">The Problem</div>
                <ul className="space-y-4">
                  {problems.map((p) => (
                    <li key={p} className="flex items-start gap-3">
                      <span className="h-6 w-6 rounded-full bg-destructive/10 flex items-center justify-center mt-0.5">
                        <X className="h-3.5 w-3.5 text-destructive" />
                      </span>
                      <span className="text-muted-foreground">{p}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div className="rounded-2xl border border-primary/30 bg-gradient-to-b from-primary/10 to-card p-8 shadow-glow">
                <div className="text-xs uppercase tracking-widest text-primary mb-4">Our Solution</div>
                <ul className="space-y-4">
                  {solutions.map((s) => (
                    <li key={s} className="flex items-start gap-3">
                      <span className="h-6 w-6 rounded-full bg-primary/20 flex items-center justify-center mt-0.5">
                        <Check className="h-3.5 w-3.5 text-primary" />
                      </span>
                      <span className="text-foreground">{s}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </section>
      );
    };
    
    export default ProblemSolution;@tailwind base;
    @tailwind components;
    @tailwind utilities;
    
