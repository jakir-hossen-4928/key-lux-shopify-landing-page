
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-container-{{ ai_gen_id }} {
    display: block;
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    border-bottom: {{ block.settings.border_bottom_width }}px {{ block.settings.border_bottom_style }} {{ block.settings.border_bottom_color }};
    width: 100%;
  }

  .ai-hero-gradient-overlay-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, {{ block.settings.gradient_color }} 0%, transparent 70%);
    opacity: {{ block.settings.gradient_opacity }};
    pointer-events: none;
  }

  .ai-hero-content-wrapper-{{ ai_gen_id }} {
    position: relative;
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-hero-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.grid_gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
  }

  @media (min-width: 990px) {
    .ai-hero-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.grid_gap_desktop }}px;
    }

    {% if block.settings.reverse_columns_desktop %}
      .ai-hero-text-content-{{ ai_gen_id }} {
        order: 2;
      }
      .ai-hero-image-content-{{ ai_gen_id }} {
        order: 1;
      }
    {% endif %}
  }

  .ai-hero-text-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_content_gap }}px;
  }

  .ai-hero-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: {{ block.settings.badge_gap }}px;
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    border: {{ block.settings.badge_border_width }}px {{ block.settings.badge_border_style }} {{ block.settings.badge_border_color }};
    background-color: {{ block.settings.badge_bg_color }};
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    text-transform: {{ block.settings.badge_text_transform }};
    letter-spacing: {{ block.settings.badge_letter_spacing }};
    color: {{ block.settings.badge_text_color }};
    width: fit-content;
  }

  .ai-hero-badge-dot-{{ ai_gen_id }} {
    width: {{ block.settings.badge_dot_size }}px;
    height: {{ block.settings.badge_dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.badge_dot_color }};
    animation: ai-pulse-{{ ai_gen_id }} 2s ease-in-out infinite;
  }

  @keyframes ai-pulse-{{ ai_gen_id }} {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .ai-hero-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size_mobile }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    color: {{ block.settings.heading_color }};
    margin: 0;
    text-transform: {{ block.settings.heading_text_transform }};
  }

  @media (min-width: 750px) {
    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_tablet }}px;
    }
  }

  @media (min-width: 990px) {
    .ai-hero-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_desktop }}px;
    }
  }

  .ai-hero-heading-gradient-{{ ai_gen_id }} {
    background: linear-gradient(135deg, {{ block.settings.gradient_text_color_1 }}, {{ block.settings.gradient_text_color_2 }});
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .ai-hero-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    line-height: {{ block.settings.description_line_height }};
    color: {{ block.settings.description_color }};
    max-width: {{ block.settings.description_max_width }}px;
    margin: 0;
  }

  .ai-hero-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.buttons_gap }}px;
    align-items: center;
  }

  .ai-hero-button-primary-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.button_primary_icon_gap }}px;
    padding: {{ block.settings.button_primary_padding_vertical }}px {{ block.settings.button_primary_padding_horizontal }}px;
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_text_color }};
    border: {{ block.settings.button_primary_border_width }}px {{ block.settings.button_primary_border_style }} {{ block.settings.button_primary_border_color }};
    border-radius: {{ block.settings.button_primary_border_radius }}px;
    font-size: {{ block.settings.button_primary_font_size }}px;
    font-weight: {{ block.settings.button_primary_font_weight }};
    text-transform: {{ block.settings.button_primary_text_transform }};
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-hero-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_bg_hover }};
    color: {{ block.settings.button_primary_text_color_hover }};
    border-color: {{ block.settings.button_primary_border_color_hover }};
    transform: translateY({{ block.settings.button_primary_hover_translate }}px);
  }

  .ai-hero-button-secondary-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.button_secondary_icon_gap }}px;
    padding: {{ block.settings.button_secondary_padding_vertical }}px {{ block.settings.button_secondary_padding_horizontal }}px;
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_text_color }};
    border: {{ block.settings.button_secondary_border_width }}px {{ block.settings.button_secondary_border_style }} {{ block.settings.button_secondary_border_color }};
    border-radius: {{ block.settings.button_secondary_border_radius }}px;
    font-size: {{ block.settings.button_secondary_font_size }}px;
    font-weight: {{ block.settings.button_secondary_font_weight }};
    text-transform: {{ block.settings.button_secondary_text_transform }};
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-hero-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_bg_hover }};
    color: {{ block.settings.button_secondary_text_color_hover }};
    border-color: {{ block.settings.button_secondary_border_color_hover }};
    transform: translateY({{ block.settings.button_secondary_hover_translate }}px);
  }

  .ai-hero-features-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.features_gap }}px;
    padding-top: {{ block.settings.features_padding_top }}px;
  }

  .ai-hero-feature-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.feature_icon_gap }}px;
    font-size: {{ block.settings.feature_font_size }}px;
    color: {{ block.settings.feature_text_color }};
  }

  .ai-hero-feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.feature_icon_size }}px;
    height: {{ block.settings.feature_icon_size }}px;
    color: {{ block.settings.feature_icon_color }};
    flex-shrink: 0;
  }

  .ai-hero-feature-icon-img-{{ ai_gen_id }} {
    width: {{ block.settings.feature_icon_size }}px;
    height: {{ block.settings.feature_icon_size }}px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .ai-hero-image-content-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    justify-content: {{ block.settings.image_alignment }};
    align-items: center;
  }

  .ai-hero-image-glow-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    background-color: {{ block.settings.image_glow_color }};
    filter: blur({{ block.settings.image_glow_blur }}px);
    opacity: {{ block.settings.image_glow_opacity }};
    border-radius: 50%;
    animation: ai-pulse-glow-{{ ai_gen_id }} 3s ease-in-out infinite;
  }

  @keyframes ai-pulse-glow-{{ ai_gen_id }} {
    0%, 100% { opacity: {{ block.settings.image_glow_opacity }}; }
    50% { opacity: {{ block.settings.image_glow_opacity | times: 0.6 }}; }
  }

  .ai-hero-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.image_max_width }}px;
  }

  .ai-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    box-shadow: {{ block.settings.image_shadow_x }}px {{ block.settings.image_shadow_y }}px {{ block.settings.image_shadow_blur }}px {{ block.settings.image_shadow_color }};
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    object-fit: {{ block.settings.image_object_fit }};
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: {{ block.settings.placeholder_bg_color }};
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  @media (max-width: 989px) {
    .ai-hero-content-wrapper-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    {% if block.settings.mobile_image_position == 'top' %}
      .ai-hero-text-content-{{ ai_gen_id }} {
        order: 2;
      }
      .ai-hero-image-content-{{ ai_gen_id }} {
        order: 1;
      }
    {% elsif block.settings.mobile_image_position == 'bottom' %}
      .ai-hero-text-content-{{ ai_gen_id }} {
        order: 1;
      }
      .ai-hero-image-content-{{ ai_gen_id }} {
        order: 2;
      }
    {% endif %}

    .ai-hero-image-wrapper-{{ ai_gen_id }} {
      max-width: {{ block.settings.image_max_width_mobile }}px;
    }

    .ai-hero-buttons-{{ ai_gen_id }} {
      {% if block.settings.mobile_buttons_full_width %}
        flex-direction: column;
        width: 100%;
      {% endif %}
    }

    .ai-hero-button-primary-{{ ai_gen_id }},
    .ai-hero-button-secondary-{{ ai_gen_id }} {
      {% if block.settings.mobile_buttons_full_width %}
        width: 100%;
      {% endif %}
    }
  }
{% endstyle %}

<ai-hero-{{ ai_gen_id }} class="ai-hero-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-gradient-overlay-{{ ai_gen_id }}"></div>
  
  <div class="ai-hero-content-wrapper-{{ ai_gen_id }}">
    <div class="ai-hero-grid-{{ ai_gen_id }}">
      <div class="ai-hero-text-content-{{ ai_gen_id }}">
        {% if block.settings.show_badge %}
          <div class="ai-hero-badge-{{ ai_gen_id }}">
            {% if block.settings.show_badge_dot %}
              <span class="ai-hero-badge-dot-{{ ai_gen_id }}"></span>
            {% endif %}
            {{ block.settings.badge_text }}
          </div>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h1 class="ai-hero-heading-{{ ai_gen_id }}">
            {{ block.settings.heading_part_1 }}
            {% if block.settings.heading_part_2 != blank %}
              <br>
              <span class="ai-hero-heading-gradient-{{ ai_gen_id }}">{{ block.settings.heading_part_2 }}</span>
            {% endif %}
            {% if block.settings.heading_part_3 != blank %}
              {{ block.settings.heading_part_3 }}
            {% endif %}
          </h1>
        {% endif %}

        {% if block.settings.description != blank %}
          <p class="ai-hero-description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </p>
        {% endif %}

        <div class="ai-hero-buttons-{{ ai_gen_id }}">
          {% if block.settings.show_button_primary and block.settings.button_primary_text != blank %}
            <a 
              href="{{ block.settings.button_primary_link }}" 
              class="ai-hero-button-primary-{{ ai_gen_id }}"
            >
              {{ block.settings.button_primary_text }}
              {% if block.settings.button_primary_show_icon %}
                <svg class="ai-hero-button-icon-{{ ai_gen_id }}" width="{{ block.settings.button_primary_icon_size }}" height="{{ block.settings.button_primary_icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              {% endif %}
            </a>
          {% endif %}

          {% if block.settings.show_button_secondary and block.settings.button_secondary_text != blank %}
            <a 
              href="{{ block.settings.button_secondary_link }}" 
              class="ai-hero-button-secondary-{{ ai_gen_id }}"
            >
              {{ block.settings.button_secondary_text }}
            </a>
          {% endif %}
        </div>

        {% if block.settings.show_features %}
          <div class="ai-hero-features-{{ ai_gen_id }}">
            {% if block.settings.feature_1_text != blank %}
              <div class="ai-hero-feature-item-{{ ai_gen_id }}">
                {% if block.settings.feature_1_custom_icon %}
                  <img 
                    src="{{ block.settings.feature_1_custom_icon | image_url: width: 100 }}" 
                    alt="{{ block.settings.feature_1_text }}"
                    class="ai-hero-feature-icon-img-{{ ai_gen_id }}"
                    loading="lazy"
                  >
                {% else %}
                  <svg class="ai-hero-feature-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    {% if block.settings.feature_1_icon == 'truck' %}
                      <rect x="1" y="3" width="15" height="13"></rect>
                      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                      <circle cx="5.5" cy="18.5" r="2.5"></circle>
                      <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    {% elsif block.settings.feature_1_icon == 'shield' %}
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                      <path d="M9 12l2 2 4-4"></path>
                    {% elsif block.settings.feature_1_icon == 'lock' %}
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    {% endif %}
                  </svg>
                {% endif %}
                {{ block.settings.feature_1_text }}
              </div>
            {% endif %}

            {% if block.settings.feature_2_text != blank %}
              <div class="ai-hero-feature-item-{{ ai_gen_id }}">
                {% if block.settings.feature_2_custom_icon %}
                  <img 
                    src="{{ block.settings.feature_2_custom_icon | image_url: width: 100 }}" 
                    alt="{{ block.settings.feature_2_text }}"
                    class="ai-hero-feature-icon-img-{{ ai_gen_id }}"
                    loading="lazy"
                  >
                {% else %}
                  <svg class="ai-hero-feature-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    {% if block.settings.feature_2_icon == 'truck' %}
                      <rect x="1" y="3" width="15" height="13"></rect>
                      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                      <circle cx="5.5" cy="18.5" r="2.5"></circle>
                      <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    {% elsif block.settings.feature_2_icon == 'shield' %}
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                      <path d="M9 12l2 2 4-4"></path>
                    {% elsif block.settings.feature_2_icon == 'lock' %}
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    {% endif %}
                  </svg>
                {% endif %}
                {{ block.settings.feature_2_text }}
              </div>
            {% endif %}

            {% if block.settings.feature_3_text != blank %}
              <div class="ai-hero-feature-item-{{ ai_gen_id }}">
                {% if block.settings.feature_3_custom_icon %}
                  <img 
                    src="{{ block.settings.feature_3_custom_icon | image_url: width: 100 }}" 
                    alt="{{ block.settings.feature_3_text }}"
                    class="ai-hero-feature-icon-img-{{ ai_gen_id }}"
                    loading="lazy"
                  >
                {% else %}
                  <svg class="ai-hero-feature-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    {% if block.settings.feature_3_icon == 'truck' %}
                      <rect x="1" y="3" width="15" height="13"></rect>
                      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                      <circle cx="5.5" cy="18.5" r="2.5"></circle>
                      <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    {% elsif block.settings.feature_3_icon == 'shield' %}
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                      <path d="M9 12l2 2 4-4"></path>
                    {% elsif block.settings.feature_3_icon == 'lock' %}
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    {% endif %}
                  </svg>
                {% endif %}
                {{ block.settings.feature_3_text }}
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <div class="ai-hero-image-content-{{ ai_gen_id }}">
        {% if block.settings.show_image_glow %}
          <div class="ai-hero-image-glow-{{ ai_gen_id }}"></div>
        {% endif %}
        
        <div class="ai-hero-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.hero_image %}
            <img
              src="{{ block.settings.hero_image | image_url: width: 2000 }}"
              alt="{{ block.settings.hero_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.hero_image.width }}"
              height="{{ block.settings.hero_image.height }}"
              class="ai-hero-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-hero-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</ai-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class AiHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const buttons = this.querySelectorAll('.ai-hero-button-primary-{{ ai_gen_id }}, .ai-hero-button-secondary-{{ ai_gen_id }}');
        buttons.forEach(button => {
          button.addEventListener('click', (e) => {
            if (!button.getAttribute('href') || button.getAttribute('href') === '') {
              e.preventDefault();
            }
          });
        });
      }
    }

    customElements.define('ai-hero-{{ ai_gen_id }}', AiHero{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Premium hero",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Container max width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Top padding (desktop)",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Bottom padding (desktop)",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "label": "Horizontal padding (desktop)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_horizontal_mobile",
      "label": "Horizontal padding (mobile)",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#0a0a0a"
    },
    {
      "type": "range",
      "id": "border_bottom_width",
      "label": "Border bottom width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "select",
      "id": "border_bottom_style",
      "label": "Border bottom style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "border_bottom_color",
      "label": "Border bottom color",
      "default": "#262626"
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap (mobile)",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "grid_gap_desktop",
      "label": "Grid gap (desktop)",
      "min": 10,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        { "value": "start", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "end", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "reverse_columns_desktop",
      "label": "Reverse columns on desktop",
      "default": false
    },
    {
      "type": "range",
      "id": "text_content_gap",
      "label": "Text content gap",
      "min": 10,
      "max": 60,
