<script>
  (function() {
    class TrustBadges{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.slider = null;
        this.autoSlideInterval = null;
        this.currentIndex = 0;
      }

      connectedCallback() {
        this.slider = this.querySelector('[data-slider]');
        
        if (this.slider && window.innerWidth < 768) {
          this.startAutoSlide();
        }

        window.addEventListener('resize', () => {
          if (window.innerWidth < 768 && this.slider && !this.autoSlideInterval) {
            this.startAutoSlide();
          } else if (window.innerWidth >= 768 && this.autoSlideInterval) {
            this.stopAutoSlide();
          }
        });
      }

      startAutoSlide() {
        if (!this.slider) return;
        
        const slides = this.slider.querySelectorAll('.ai-trust-badges__slide-{{ ai_gen_id }}');
        if (slides.length === 0) return;

        this.autoSlideInterval = setInterval(() => {
          this.currentIndex = (this.currentIndex + 1) % slides.length;
          const slideWidth = slides[0].offsetWidth + {{ block.settings.gap_mobile }};
          this.slider.scrollTo({
            left: slideWidth * this.currentIndex,
            behavior: 'smooth'
          });
        }, {{ block.settings.auto_slide_interval | times: 1000 }});
      }

      stopAutoSlide() {
        if (this.autoSlideInterval) {
          clearInterval(this.autoSlideInterval);
          this.autoSlideInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoSlide();
      }
    }

    customElements.define('trust-badges-{{ ai_gen_id }}', TrustBadges{{ ai_gen_id }});
  })();
</script>

