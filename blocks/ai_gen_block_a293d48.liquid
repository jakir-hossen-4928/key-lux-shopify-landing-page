{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badges-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    border-bottom: {{ block.settings.border_width }}px {{ block.settings.border_style }} {{ block.settings.border_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    width: 100%;
  }

  .ai-trust-badges__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-trust-badges__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-trust-badges__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    gap: {{ block.settings.gap_mobile }}px;
    justify-items: {{ block.settings.justify_items_mobile }};
  }

  .ai-trust-badges__slider-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap_mobile }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    justify-content: center;
  }

  .ai-trust-badges__slider-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-trust-badges__slide-{{ ai_gen_id }} {
    flex: 0 0 auto;
    scroll-snap-align: center;
    width: calc(100% - {{ block.settings.gap_mobile }}px);
    display: flex;
    justify-content: center;
  }

  .ai-trust-badges__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    align-items: {{ block.settings.align_items_mobile }};
    text-align: {{ block.settings.text_align_mobile }};
    gap: {{ block.settings.item_gap }}px;
  }

  .ai-trust-badges__icon-container-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    border-radius: {{ block.settings.icon_border_radius }}px;
    background-color: {{ block.settings.icon_background_color }};
    border: {{ block.settings.icon_border_width }}px {{ block.settings.icon_border_style }} {{ block.settings.icon_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .ai-trust-badges__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_svg_size }}px;
    height: {{ block.settings.icon_svg_size }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-trust-badges__icon-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.icon_image_fit }};
  }

  .ai-trust-badges__text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_gap }}px;
  }

  .ai-trust-badges__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: {{ block.settings.label_font_weight }};
    color: {{ block.settings.label_color }};
    margin: 0;
    line-height: {{ block.settings.label_line_height }};
  }

  .ai-trust-badges__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_font_size }}px;
    font-weight: {{ block.settings.subtitle_font_weight }};
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: {{ block.settings.subtitle_line_height }};
  }

  @media screen and (min-width: 768px) {
    .ai-trust-badges__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      gap: {{ block.settings.gap_desktop }}px;
      justify-items: {{ block.settings.justify_items_desktop }};
    }

    .ai-trust-badges__item-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.flex_direction_desktop }};
      align-items: {{ block.settings.align_items_desktop }};
      text-align: {{ block.settings.text_align_desktop }};
    }
  }
{% endstyle %}

