{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-features-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-features-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-features-header-{{ ai_gen_id }} {
    text-align: center;
    max-width: {{ block.settings.header_max_width }}px;
    margin: 0 auto {{ block.settings.header_margin_bottom }}px;
  }

  .ai-features-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    text-transform: uppercase;
    letter-spacing: {{ block.settings.label_letter_spacing }}em;
    color: {{ block.settings.label_color }};
    margin-bottom: {{ block.settings.label_margin_bottom }}px;
    font-weight: {{ block.settings.label_font_weight }};
  }

  .ai-features-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}em;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-features-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-features-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    }

    .ai-features-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_desktop }}px;
    }
  }

  .ai-features-card-{{ ai_gen_id }} {
    border-radius: {{ block.settings.card_border_radius }}px;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    background-color: {{ block.settings.card_background_color }};
    padding: {{ block.settings.card_padding }}px;
    transition: all 0.3s ease;
  }

  .ai-features-card-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.card_border_hover_color }};
    box-shadow: 0 0 {{ block.settings.card_hover_glow_size }}px {{ block.settings.card_hover_glow_color }};
    transform: translateY({{ block.settings.card_hover_translate_y }}px);
  }

  .ai-features-icon-wrapper-{{ ai_gen_id }} {
    height: {{ block.settings.icon_size }}px;
    width: {{ block.settings.icon_size }}px;
    border-radius: {{ block.settings.icon_border_radius }}px;
    background: {{ block.settings.icon_background_gradient }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ block.settings.icon_margin_bottom }}px;
    transition: transform 0.3s ease;
  }

  .ai-features-card-{{ ai_gen_id }}:hover .ai-features-icon-wrapper-{{ ai_gen_id }} {
    transform: scale({{ block.settings.icon_hover_scale }});
  }

  .ai-features-icon-wrapper-{{ ai_gen_id }} img {
    width: {{ block.settings.icon_image_size }}px;
    height: {{ block.settings.icon_image_size }}px;
    object-fit: contain;
  }

  .ai-features-icon-wrapper-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_image_size }}px;
    height: {{ block.settings.icon_image_size }}px;
  }

  .ai-features-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_font_size }}px;
    font-weight: {{ block.settings.card_title_font_weight }};
    color: {{ block.settings.card_title_color }};
    margin: 0 0 {{ block.settings.card_title_margin_bottom }}px;
  }

  .ai-features-card-desc-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_desc_font_size }}px;
    line-height: {{ block.settings.card_desc_line_height }};
    color: {{ block.settings.card_desc_color }};
    margin: 0;
  }
{% endstyle %}

<ai-features-section-{{ ai_gen_id }} class="ai-features-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-features-container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-features-header-{{ ai_gen_id }}">
        {% if block.settings.label != blank %}
          <div class="ai-features-label-{{ ai_gen_id }}">{{ block.settings.label }}</div>
        {% endif %}
        {% if block.settings.heading != blank %}
          <h2 class="ai-features-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-features-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign feature_enabled_key = 'feature_' | append: i | append: '_enabled'
          assign feature_icon_key = 'feature_' | append: i | append: '_icon'
          assign feature_title_key = 'feature_' | append: i | append: '_title'
          assign feature_desc_key = 'feature_' | append: i | append: '_desc'

          assign feature_enabled = block.settings[feature_enabled_key]
          assign feature_icon = block.settings[feature_icon_key]
          assign feature_title = block.settings[feature_title_key]
          assign feature_desc = block.settings[feature_desc_key]
        %}

        {% if feature_enabled %}
          <div class="ai-features-card-{{ ai_gen_id }}">
            <div class="ai-features-icon-wrapper-{{ ai_gen_id }}">
              {% if feature_icon != blank %}
                <img
                  src="{{ feature_icon | image_url: width: 200 }}"
                  alt="{{ feature_title | escape }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.icon_fallback_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="12" y1="8" x2="12" y2="12"></line>
                  <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
              {% endif %}
            </div>
            <h3 class="ai-features-card-title-{{ ai_gen_id }}">{{ feature_title }}</h3>
            <p class="ai-features-card-desc-{{ ai_gen_id }}">{{ feature_desc }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</ai-features-section-{{ ai_gen_id }}>

<script>
  (function() {
    class AiFeaturesSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeObserver();
      }

      initializeObserver() {
        const cards = this.querySelectorAll('.ai-features-card-{{ ai_gen_id }}');
        
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }
            });
          }, {
            threshold: 0.1
          });

          cards.forEach((card, index) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            card.style.transition = `opacity 0.6s ease ${index * 0.1}s, transform 0.6s ease ${index * 0.1}s`;
            observer.observe(card);
          });
        }
      }
    }

    customElements.define('ai-features-section-{{ ai_gen_id }}', AiFeaturesSection{{ ai_gen_id }});
  })();
</script>

