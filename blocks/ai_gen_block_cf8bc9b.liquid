{% doc %}
  @prompt
    create a section of feutersa .import { Fingerprint, Droplets, Shield, KeyRound } from "lucide-react";
    
    const features = [
      { icon: Fingerprint, title: "Secure Fit", desc: "Precision-molded to grip your key perfectly with zero rattle." },
      { icon: Droplets, title: "Water Resistant", desc: "IPX5 rated. Weather, sweat, or spills — fully protected." },
      { icon: Shield, title: "Scratch Proof", desc: "Aerospace-grade coating keeps it pristine, year after year." },
      { icon: KeyRound, title: "Universal Fit", desc: "Compatible with all major car brands and key models." },
    ];
    
    const Features = () => {
      return (
        <section className="py-24 border-b border-border">
          <div className="container">
            <div className="text-center max-w-2xl mx-auto mb-16">
              <div className="text-xs uppercase tracking-widest text-primary mb-3">Features</div>
              <h2 className="text-4xl md:text-5xl font-black tracking-tight">Built without compromise</h2>
            </div>
            <div className="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
              {features.map(({ icon: Icon, title, desc }) => (
                <div key={title} className="group rounded-2xl border border-border bg-card p-6 hover:border-primary/50 hover:shadow-glow transition-all duration-300">
                  <div className="h-12 w-12 rounded-xl bg-gradient-primary flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
                    <Icon className="h-5 w-5 text-primary-foreground" />
                  </div>
                  <h3 className="font-semibold text-lg mb-2">{title}</h3>
                  <p className="text-sm text-muted-foreground leading-relaxed">{desc}</p>
                </div>
              ))}
            </div>
          </div>
        </section>
      );
    };
    
    export default Features;@tailwind base;
    @tailwind components;
    @tailwind utilities;
    
