{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-product-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-featured-product-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.container_padding_x }}px;
  }

  .ai-featured-product-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.grid_gap_mobile }}px;
  }

  @media (min-width: 990px) {
    .ai-featured-product-grid-{{ ai_gen_id }} {
      grid-template-columns: {{ block.settings.image_column_width }}% {{ block.settings.info_column_width }}%;
      gap: {{ block.settings.grid_gap }}px;
    }
  }

  .ai-featured-product-images-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.image_gap }}px;
  }

  .ai-featured-product-main-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    border: {{ block.settings.image_border_width }}px solid {{ block.settings.image_border_color }};
    background-color: {{ block.settings.image_bg_color }};
    width: 100%;
    height: {{ block.settings.main_image_height_mobile }}px;
  }

  @media (min-width: 750px) {
    .ai-featured-product-main-image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.main_image_height }}px;
    }
  }

  .ai-featured-product-main-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_object_fit }};
    transition: transform {{ block.settings.image_hover_duration }}s ease;
  }

  .ai-featured-product-main-image-wrapper-{{ ai_gen_id }}:hover .ai-featured-product-main-image-{{ ai_gen_id }} {
    {% if block.settings.enable_image_hover %}
      transform: scale({{ block.settings.image_hover_scale }});
    {% endif %}
  }

  .ai-featured-product-thumbnails-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.thumbnail_columns_mobile }}, 1fr);
    gap: {{ block.settings.thumbnail_gap }}px;
  }

  @media (min-width: 750px) {
    .ai-featured-product-thumbnails-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.thumbnail_columns }}, 1fr);
    }
  }

  .ai-featured-product-thumbnail-{{ ai_gen_id }} {
    overflow: hidden;
    border-radius: {{ block.settings.thumbnail_border_radius }}px;
    border: {{ block.settings.thumbnail_border_width }}px solid {{ block.settings.thumbnail_border_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: {{ block.settings.thumbnail_opacity }};
    height: {{ block.settings.thumbnail_height }}px;
  }

  .ai-featured-product-thumbnail-{{ ai_gen_id }}:hover {
    opacity: {{ block.settings.thumbnail_hover_opacity }};
  }

  .ai-featured-product-thumbnail-{{ ai_gen_id }}.active {
    border-color: {{ block.settings.thumbnail_active_border_color }};
    opacity: 1;
    box-shadow: 0 0 {{ block.settings.thumbnail_glow_size }}px {{ block.settings.thumbnail_glow_color }};
  }

  .ai-featured-product-thumbnail-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.thumbnail_object_fit }};
  }

  .ai-featured-product-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.info_gap }}px;
  }

  @media (min-width: 990px) {
    .ai-featured-product-info-{{ ai_gen_id }} {
      padding: {{ block.settings.info_padding_desktop }}px 0;
    }
  }

  .ai-featured-product-badge-{{ ai_gen_id }} {
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    text-transform: {{ block.settings.badge_text_transform }};
    letter-spacing: {{ block.settings.badge_letter_spacing }};
    color: {{ block.settings.badge_color }};
    background-color: {{ block.settings.badge_bg_color }};
    padding: {{ block.settings.badge_padding_y }}px {{ block.settings.badge_padding_x }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    display: inline-block;
    margin-bottom: {{ block.settings.badge_margin_bottom }}px;
  }

  .ai-featured-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size_mobile }}px;
    font-weight: {{ block.settings.title_font_weight }};
    line-height: {{ block.settings.title_line_height }};
    letter-spacing: {{ block.settings.title_letter_spacing }};
    color: {{ block.settings.title_color }};
    text-transform: {{ block.settings.title_text_transform }};
    margin: 0;
  }

  @media (min-width: 750px) {
    .ai-featured-product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size }}px;
    }
  }

  .ai-featured-product-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.rating_gap }}px;
  }

  .ai-featured-product-stars-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.star_gap }}px;
  }

  .ai-featured-product-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
    color: {{ block.settings.star_color }};
  }

  .ai-featured-product-rating-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.rating_text_size }}px;
    font-weight: {{ block.settings.rating_text_weight }};
    color: {{ block.settings.rating_text_color }};
  }

  .ai-featured-product-price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: baseline;
    gap: {{ block.settings.price_gap }}px;
    flex-wrap: wrap;
  }

  .ai-featured-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    font-weight: {{ block.settings.price_font_weight }};
    color: {{ block.settings.price_color }};
  }

  .ai-featured-product-compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_font_size }}px;
    font-weight: {{ block.settings.compare_price_font_weight }};
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-featured-product-discount-badge-{{ ai_gen_id }} {
    font-size: {{ block.settings.discount_badge_font_size }}px;
    font-weight: {{ block.settings.discount_badge_font_weight }};
    text-transform: {{ block.settings.discount_badge_text_transform }};
    color: {{ block.settings.discount_badge_text_color }};
    background-color: {{ block.settings.discount_badge_bg_color }};
    padding: {{ block.settings.discount_badge_padding_y }}px {{ block.settings.discount_badge_padding_x }}px;
    border-radius: {{ block.settings.discount_badge_border_radius }}px;
  }

  .ai-featured-product-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size_mobile }}px;
    font-weight: {{ block.settings.description_font_weight }};
    line-height: {{ block.settings.description_line_height }};
    color: {{ block.settings.description_color }};
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: {{ block.settings.description_lines_mobile }};
    -webkit-box-orient: vertical;
  }

  @media (min-width: 750px) {
    .ai-featured-product-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size }}px;
      -webkit-line-clamp: {{ block.settings.description_lines_desktop }};
    }
  }

  .ai-featured-product-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.button_gap }}px;
  }

  .ai-featured-product-button-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.button_height }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-transform: {{ block.settings.button_text_transform }};
    letter-spacing: {{ block.settings.button_letter_spacing }};
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-featured-product-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-featured-product-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_text }};
    border: {{ block.settings.button_primary_border_width }}px solid {{ block.settings.button_primary_border_color }};
  }

  .ai-featured-product-button-primary-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.button_primary_bg_hover }};
    color: {{ block.settings.button_primary_text_hover }};
    border-color: {{ block.settings.button_primary_border_color_hover }};
  }

  .ai-featured-product-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_text }};
    border: {{ block.settings.button_secondary_border_width }}px solid {{ block.settings.button_secondary_border_color }};
  }

  .ai-featured-product-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_bg_hover }};
    color: {{ block.settings.button_secondary_text_hover }};
    border-color: {{ block.settings.button_secondary_border_color_hover }};
  }

  .ai-featured-product-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.description_color }};
  }

  .ai-featured-product-placeholder-{{ ai_gen_id }} {
    background-color: {{ block.settings.image_bg_color }};
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-featured-product-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-featured-product-loading-{{ ai_gen_id }} {
    display: none;
    margin-left: 8px;
  }

  .ai-featured-product-loading-{{ ai_gen_id }}.active {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    animation: ai-spin-{{ ai_gen_id }} 0.6s linear infinite;
  }

  @keyframes ai-spin-{{ ai_gen_id }} {
    to { transform: rotate(360deg); }
  }
{% endstyle %}

<featured-product-{{ ai_gen_id }} class="ai-featured-product-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-product-container-{{ ai_gen_id }}">
    {% if block.settings.featured_product %}
      {% assign product = block.settings.featured_product %}
      <div class="ai-featured-product-grid-{{ ai_gen_id }}">
        <div class="ai-featured-product-images-{{ ai_gen_id }}">
          <div class="ai-featured-product-main-image-wrapper-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 1280 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy"
                width="1280"
                height="1280"
                class="ai-featured-product-main-image-{{ ai_gen_id }}"
                data-main-image
              >
            {% else %}
              <div class="ai-featured-product-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          {% if product.images.size > 1 %}
            <div class="ai-featured-product-thumbnails-{{ ai_gen_id }}">
              {% for image in product.images limit: block.settings.thumbnail_limit %}
                <button
                  class="ai-featured-product-thumbnail-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
                  data-thumbnail
                  data-image-url="{{ image | image_url: width: 1280 }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  <img
                    src="{{ image | image_url: width: 200 }}"
                    alt="{{ image.alt | escape }}"
                    loading="lazy"
                    class="ai-featured-product-thumbnail-image-{{ ai_gen_id }}"
                  >
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <div class="ai-featured-product-info-{{ ai_gen_id }}">
          {% if block.settings.show_badge and block.settings.badge_text != blank %}
            <div class="ai-featured-product-badge-{{ ai_gen_id }}">
              {{ block.settings.badge_text }}
            </div>
          {% endif %}

          <h2 class="ai-featured-product-title-{{ ai_gen_id }}">
            {{ product.title }}
          </h2>

          {% if block.settings.show_rating %}
            <div class="ai-featured-product-rating-{{ ai_gen_id }}">
              <div class="ai-featured-product-stars-{{ ai_gen_id }}">
                {% for i in (1..5) %}
                  <svg class="ai-featured-product-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                  </svg>
                {% endfor %}
              </div>
              <span class="ai-featured-product-rating-text-{{ ai_gen_id }}">
                {{ block.settings.rating_value }} · {{ block.settings.review_count }} reviews
              </span>
            </div>
          {% endif %}

          <div class="ai-featured-product-price-wrapper-{{ ai_gen_id }}">
            <span class="ai-featured-product-price-{{ ai_gen_id }}">
              {{ product.price | money }}
            </span>
            {% if product.compare_at_price > product.price %}
              <span class="ai-featured-product-compare-price-{{ ai_gen_id }}">
                {{ product.compare_at_price | money }}
              </span>
              {% if block.settings.show_discount_badge %}
                {% assign discount_percent = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                <span class="ai-featured-product-discount-badge-{{ ai_gen_id }}">
                  {{ discount_percent }}% OFF
                </span>
              {% endif %}
            {% endif %}
          </div>

          {% if block.settings.show_description and product.description != blank %}
            <div class="ai-featured-product-description-{{ ai_gen_id }}">
              {{ product.description | strip_html }}
            </div>
          {% endif %}

          <div class="ai-featured-product-buttons-{{ ai_gen_id }}">
            {% if block.settings.show_add_to_cart %}
              <button
                class="ai-featured-product-button-{{ ai_gen_id }} ai-featured-product-button-primary-{{ ai_gen_id }}"
                data-add-to-cart
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
              >
                {{ block.settings.add_to_cart_text }}
                <span class="ai-featured-product-loading-{{ ai_gen_id }}" data-loading></span>
              </button>
            {% endif %}
            {% if block.settings.show_buy_now %}
              <button
                class="ai-featured-product-button-{{ ai_gen_id }} ai-featured-product-button-secondary-{{ ai_gen_id }}"
                data-buy-now
                data-variant-id="{{ product.selected_or_first_available_variant.id }}"
              >
                {{ block.settings.buy_now_text }}
                <span class="ai-featured-product-loading-{{ ai_gen_id }}" data-loading></span>
              </button>
            {% endif %}
          </div>
        </div>
      </div>
    {% else %}
      <div class="ai-featured-product-empty-state-{{ ai_gen_id }}">
        <p>Select a product to feature</p>
      </div>
    {% endif %}
  </div>
</featured-product-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedProduct{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.thumbnails = this.querySelectorAll('[data-thumbnail]');
        this.mainImage = this.querySelector('[data-main-image]');
        this.addToCartButton = this.querySelector('[data-add-to-cart]');
        this.buyNowButton = this.querySelector('[data-buy-now]');
        
        this.setupThumbnails();
        this.setupAddToCart();
        this.setupBuyNow();
      }

      setupThumbnails() {
        if (!this.thumbnails.length || !this.mainImage) return;

        this.thumbnails.forEach((thumbnail) => {
          thumbnail.addEventListener('click', () => {
            this.thumbnails.forEach((t) => t.classList.remove('active'));
            thumbnail.classList.add('active');
            
            const imageUrl = thumbnail.getAttribute('data-image-url');
            if (imageUrl) {
              this.mainImage.src = imageUrl;
            }
          });
        });
      }

      setupAddToCart() {
        if (!this.addToCartButton) return;

        this.addToCartButton.addEventListener('click', () => {
          const variantId = this.addToCartButton.getAttribute('data-variant-id');
          const loadingSpinner = this.addToCartButton.querySelector('[data-loading]');
          
          if (!variantId) return;

          this.addToCartButton.disabled = true;
          if (loadingSpinner) loadingSpinner.classList.add('active');

          fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              id: variantId,
              quantity: 1
            })
          })
          .then(response => response.json())
          .then(data => {
            if (window.theme && window.theme.cart) {
              window.theme.cart.refresh();
            }
            
            if (document.querySelector('cart-drawer')) {
              document.querySelector('cart-drawer').open();
            } else {
              window.location.href = '/cart';
            }
          })
          .catch((error) => {
            console.error('Error:', error);
            alert('Failed to add item to cart. Please try again.');
          })
          .finally(() => {
            this.addToCartButton.disabled = false;
            if (loadingSpinner) loadingSpinner.classList.remove('active');
          });
        });
      }

      setupBuyNow() {
        if (!this.buyNowButton) return;

        this.buyNowButton.addEventListener('click', () => {
          const variantId = this.buyNowButton.getAttribute('data-variant-id');
          const loadingSpinner = this.buyNowButton.querySelector('[data-loading]');
          
          if (!variantId) return;

          this.buyNowButton.disabled = true;
          if (loadingSpinner) loadingSpinner.classList.add('active');

          fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              id: variantId,
              quantity: 1
            })
          })
          .then(response => response.json())
          .then(data => {
            window.location.href = '/checkout';
          })
          .catch((error) => {
            console.error('Error:', error);
            alert('Failed to process. Please try again.');
            this.buyNowButton.disabled = false;
            if (loadingSpinner) loadingSpinner.classList.remove('active');
          });
        });
      }
    }

    customElements.define('featured-product-{{ ai_gen_id }}', FeaturedProduct{{ ai_gen_id }});
  })();
</script>

