{% doc %}
  @prompt
    create  review section based on this code import { Star } from "lucide-react";
    
    const reviews = [
      { name: "Marcus T.", rating: 5, text: "Feels like a luxury upgrade 🔥. Fits my BMW key perfectly and looks stunning." },
      { name: "Sophia L.", rating: 5, text: "The build quality is unreal. Way better than the $20 ones I tried before." },
      { name: "Daniel R.", rating: 5, text: "Compliments every time someone sees it. Worth every penny." },
      { name: "Aisha K.", rating: 5, text: "Survived a coffee spill and a drop in the parking lot. Still flawless." },
      { name: "James P.", rating: 5, text: "Premium feel, premium look. My Audi finally has a key worthy of it." },
    ];
    
    const Reviews = () => {
      return (
        <section className="py-24 border-b border-border">
          <div className="container">
            <div className="text-center max-w-2xl mx-auto mb-16">
              <div className="text-xs uppercase tracking-widest text-primary mb-3">Reviews</div>
              <h2 className="text-4xl md:text-5xl font-black tracking-tight">Loved by 10,000+ drivers</h2>
            </div>
            <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {reviews.slice(0, 3).map((r) => (
                <ReviewCard key={r.name} {...r} />
              ))}
            </div>
            <div className="grid md:grid-cols-2 gap-6 mt-6 max-w-4xl mx-auto">
              {reviews.slice(3).map((r) => (
                <ReviewCard key={r.name} {...r} />
              ))}
            </div>
          </div>
        </section>
      );
    };
    
    const ReviewCard = ({ name, rating, text }: { name: string; rating: number; text: string }) => (
      <div className="rounded-2xl border border-border bg-card p-6 hover:border-primary/40 transition-colors">
        <div className="flex gap-0.5 mb-3">
          {Array.from({ length: rating }).map((_, i) => (
            <Star key={i} className="h-4 w-4 fill-primary text-primary" />
          ))}
        </div>
        <p className="text-foreground mb-4 leading-relaxed">"{text}"</p>
        <div className="text-sm text-muted-foreground font-medium">— {name}</div>
      </div>
    );
    
    export default Reviews;@tailwind base;
    @tailwind components;
    @tailwind utilities;
    
