{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_left_right }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-bottom: {{ block.settings.border_bottom_width }}px {{ block.settings.border_bottom_style }} {{ block.settings.border_bottom_color }};
    border-top: {{ block.settings.border_top_width }}px {{ block.settings.border_top_style }} {{ block.settings.border_top_color }};
  }

  .ai-reviews-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.container_padding_left_right }}px;
  }

  .ai-reviews-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_text_align }};
    max-width: {{ block.settings.header_max_width }}px;
    margin: 0 auto {{ block.settings.header_margin_bottom }}px;
    padding: {{ block.settings.header_padding_top }}px {{ block.settings.header_padding_left_right }}px {{ block.settings.header_padding_bottom }}px;
    background-color: {{ block.settings.header_background_color }};
    border-radius: {{ block.settings.header_border_radius }}px;
  }

  .ai-reviews-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_font_size }}px;
    text-transform: {{ block.settings.eyebrow_text_transform }};
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }};
    color: {{ block.settings.eyebrow_color }};
    margin-bottom: {{ block.settings.eyebrow_margin_bottom }}px;
    font-weight: {{ block.settings.eyebrow_font_weight }};
    line-height: {{ block.settings.eyebrow_line_height }};
  }

  .ai-reviews-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    line-height: {{ block.settings.title_line_height }};
    letter-spacing: {{ block.settings.title_letter_spacing }};
    color: {{ block.settings.title_color }};
    margin: 0;
    text-transform: {{ block.settings.title_text_transform }};
  }

  .ai-reviews-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.grid_columns_desktop }}, 1fr);
    gap: {{ block.settings.card_gap }}px;
    margin-bottom: {{ block.settings.grid_margin_bottom }}px;
  }

  .ai-reviews-grid-bottom-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.grid_bottom_columns_desktop }}, 1fr);
    gap: {{ block.settings.card_gap }}px;
    max-width: {{ block.settings.grid_bottom_max_width }}px;
    margin: 0 auto;
  }

  .ai-review-card-{{ ai_gen_id }} {
    border-radius: {{ block.settings.card_border_radius }}px;
    border: {{ block.settings.card_border_width }}px {{ block.settings.card_border_style }} {{ block.settings.card_border_color }};
    background-color: {{ block.settings.card_background_color }};
    padding: {{ block.settings.card_padding_top }}px {{ block.settings.card_padding_left_right }}px {{ block.settings.card_padding_bottom }}px;
    transition: all {{ block.settings.card_transition_duration }}s ease;
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
    min-height: {{ block.settings.card_min_height }}px;
    display: flex;
    flex-direction: column;
  }

  .ai-review-card-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.card_border_hover_color }};
    background-color: {{ block.settings.card_background_hover_color }};
    transform: translateY({{ block.settings.card_hover_translate_y }}px);
    box-shadow: {{ block.settings.card_hover_shadow_x }}px {{ block.settings.card_hover_shadow_y }}px {{ block.settings.card_hover_shadow_blur }}px {{ block.settings.card_hover_shadow_color }};
  }

  .ai-review-stars-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.star_gap }}px;
    margin-bottom: {{ block.settings.stars_margin_bottom }}px;
    justify-content: {{ block.settings.stars_alignment }};
  }

  .ai-review-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_fill_color }};
    color: {{ block.settings.star_stroke_color }};
    stroke-width: {{ block.settings.star_stroke_width }};
  }

  .ai-review-text-{{ ai_gen_id }} {
    color: {{ block.settings.review_text_color }};
    margin-bottom: {{ block.settings.review_text_margin_bottom }}px;
    line-height: {{ block.settings.review_text_line_height }};
    font-size: {{ block.settings.review_text_font_size }}px;
    font-weight: {{ block.settings.review_text_font_weight }};
    letter-spacing: {{ block.settings.review_text_letter_spacing }};
    text-align: {{ block.settings.review_text_align }};
    flex-grow: 1;
  }

  .ai-review-author-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_font_size }}px;
    color: {{ block.settings.author_color }};
    font-weight: {{ block.settings.author_font_weight }};
    line-height: {{ block.settings.author_line_height }};
    letter-spacing: {{ block.settings.author_letter_spacing }};
    text-align: {{ block.settings.author_text_align }};
    text-transform: {{ block.settings.author_text_transform }};
    margin-top: {{ block.settings.author_margin_top }}px;
  }

  @media screen and (max-width: 989px) {
    .ai-reviews-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.grid_columns_tablet }}, 1fr);
    }

    .ai-reviews-grid-bottom-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.grid_bottom_columns_tablet }}, 1fr);
    }

    .ai-reviews-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_tablet }}px;
    }

    .ai-reviews-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-reviews-section-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_left_right_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-reviews-grid-{{ ai_gen_id }},
    .ai-reviews-grid-bottom-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.grid_columns_mobile }}, 1fr);
    }

    .ai-reviews-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }

    .ai-reviews-eyebrow-{{ ai_gen_id }} {
      font-size: {{ block.settings.eyebrow_font_size_mobile }}px;
    }

    .ai-review-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_top_mobile }}px {{ block.settings.card_padding_left_right_mobile }}px {{ block.settings.card_padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

<reviews-section-{{ ai_gen_id }} class="ai-reviews-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
